# Copy this file to .env and replace every placeholder before starting services.
COMPOSE_PROJECT_NAME=hiliving
POSTGRES_DB=hiliving
POSTGRES_USER=replace_with_local_username
POSTGRES_PASSWORD=replace_with_strong_local_password
POSTGRES_PORT=5432

SPRING_PROFILES_ACTIVE=local
DB_URL=jdbc:postgresql://localhost:5432/hiliving
DB_USERNAME=replace_with_local_username
DB_PASSWORD=replace_with_strong_local_password
SESSION_COOKIE_SECURE=false
HILIVING_MEDIA_STORAGE_PATH=replace_with_external_upload_directory
HILIVING_MEDIA_MULTIPART_MAX_FILE_SIZE=8MB
HILIVING_MEDIA_MULTIPART_MAX_REQUEST_SIZE=9MB
HILIVING_STANDARD_SHIPPING_FEE=5000.00

# Transactional email. Delivery and the manual test are intentionally disabled by default.
MAIL_HOST=replace_with_smtp_host
MAIL_PORT=587
MAIL_USERNAME=replace_with_smtp_username
MAIL_PASSWORD=replace_with_smtp_password
MAIL_FROM_ADDRESS=replace_with_verified_sender_address
MAIL_FROM_NAME=HiLiving
MAIL_SUPPORT_ADDRESS=replace_with_customer_support_address
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLED=true
MAIL_CONNECTION_TIMEOUT_MS=5000
MAIL_READ_TIMEOUT_MS=10000
MAIL_WRITE_TIMEOUT_MS=10000
APP_PUBLIC_URL=http://localhost:5173
EMAIL_DELIVERY_ENABLED=false
EMAIL_MANUAL_TEST_ENABLED=false
EMAIL_TEST_RECIPIENT=
# Generate a unique value locally with: openssl rand -base64 32
EMAIL_TOKEN_PROTECTION_KEY=replace_with_base64_encoded_32_byte_key
EMAIL_VERIFICATION_EXPIRY=24h
PASSWORD_RESET_EXPIRY=30m
EMAIL_OUTBOX_BATCH_SIZE=20
EMAIL_OUTBOX_POLLING_INTERVAL=10s
EMAIL_OUTBOX_MAX_ATTEMPTS=5
EMAIL_OUTBOX_INITIAL_RETRY_DELAY=1m
EMAIL_OUTBOX_MAX_RETRY_DELAY=1h
EMAIL_OUTBOX_PROCESSING_TIMEOUT=10m
EMAIL_RATE_LIMIT_MAX_ENTRIES=10000
EMAIL_VERIFICATION_RATE_LIMIT=3
EMAIL_VERIFICATION_RATE_WINDOW=1h
PASSWORD_RESET_REQUEST_RATE_LIMIT=5
PASSWORD_RESET_REQUEST_RATE_WINDOW=1h
PASSWORD_RESET_CONFIRM_RATE_LIMIT=10
PASSWORD_RESET_CONFIRM_RATE_WINDOW=15m

# Blank uses same-origin /api requests. Vite proxies them locally.
VITE_API_BASE_URL=
VITE_DEV_API_PROXY_TARGET=http://localhost:8080
